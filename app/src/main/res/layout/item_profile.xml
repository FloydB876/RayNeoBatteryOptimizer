<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_profile_item"
    android:padding="12dp"
    android:layout_marginBottom="6dp"
    android:gravity="center_vertical">

    <!-- Profile color indicator -->
    <View
        android:id="@+id/viewProfileColor"
        android:layout_width="6dp"
        android:layout_height="40dp"
        android:background="@color/profile_balanced"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balanced"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvProfileDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moderate brightness, all radios on"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"/>
    </LinearLayout>

    <!-- Active indicator -->
    <TextView
        android:id="@+id/tvActive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="● ACTIVE"
        android:textSize="14sp"
        android:textColor="@color/focus_ring"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>
